{
  "properties": {
    "displayName": "Cosmos DB Semantic Search Sandbox Policy",
    "policyType": "Custom",
    "mode": "All",
    "parameters": {
      "allowedLocations": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed locations",
          "description": "Regions permitted for learner-created resources during the lab."
        },
        "defaultValue": [
          "eastus",
          "eastus2",
          "centralus"
        ]
      },
      "allowedVmSkus": {
        "type": "Array",
        "metadata": {
          "displayName": "Allowed VM SKUs",
          "description": "Low-cost VM SKUs allowed for lab infrastructure if any learner-created VMs are deployed."
        },
        "defaultValue": [
          "Standard_B2s",
          "Standard_B2ms"
        ]
      }
    },
    "policyRule": {
      "if": {
        "anyOf": [
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Compute/virtualMachines"
              },
              {
                "not": {
                  "field": "Microsoft.Compute/virtualMachines/sku.name",
                  "in": "[parameters('allowedVmSkus')]"
                }
              }
            ]
          },
          {
            "allOf": [
              {
                "field": "type",
                "equals": "Microsoft.Storage/storageAccounts"
              },
              {
                "not": {
                  "field": "Microsoft.Storage/storageAccounts/sku.name",
                  "equals": "Standard_LRS"
                }
              }
            ]
          },
          {
            "not": {
              "field": "location",
              "in": "[parameters('allowedLocations')]"
            }
          }
        ]
      },
      "then": {
        "effect": "deny"
      }
    }
  }
}